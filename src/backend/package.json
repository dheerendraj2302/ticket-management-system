{
  "name": "support-ticket-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express API for the Support Ticket Management System",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "node migrate.js",
    "seed": "node seed.js",
    "test": "jest"
  },
  "dependencies": {
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "pg": "8.13.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.1.14",
    "supertest": "7.1.3"
  },
  "jest": {
    "testEnvironment": "node",
    "maxWorkers": 1,
    "roots": [
      "<rootDir>/../../tests"
    ],
    "moduleDirectories": [
      "node_modules",
      "<rootDir>/node_modules"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "testTimeout": 15000
  }
}
